// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         Role      @default(student)
  createdAt    DateTime  @default(now()) @map("created_at")
  sessions     Session[]

  @@map("users")
}

model Week {
  id          Int    @id @default(autoincrement())
  order       Int    @unique @map("week_order")
  themeTitle  String @map("theme_title")
  description String @default("")
  days        Day[]

  @@map("weeks")
}

model Day {
  id          Int      @id @default(autoincrement())
  weekId      Int      @map("week_id")
  order       Int      @map("day_order")
  lessonTitle String   @map("lesson_title")
  isPublished Boolean  @default(false) @map("is_published")
  updatedAt   DateTime @updatedAt @map("updated_at")
  week        Week     @relation(fields: [weekId], references: [id])
  blocks      Block[]

  @@unique([weekId, order])
  @@index([weekId])
  @@index([weekId, order])
  @@map("days")
}

model Block {
  id          String   @id @default(uuid())
  dayId       Int      @map("day_id")
  type        BlockType
  orderIndex  Int      @map("order_index")
  contentData Json     @map("content_data")
  updatedAt   DateTime @updatedAt @map("updated_at")
  day         Day      @relation(fields: [dayId], references: [id])

  @@index([dayId])
  @@index([dayId, orderIndex])
  @@map("blocks")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("sessions")
}

enum Role {
  admin
  student
}

enum BlockType {
  text
  callout
  table
  divider
  image
}

enum Level {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum PartOfSpeech {
  Noun
  Verb
  Adjective
  Adverb
  Preposition
  Conjunction
  Pronoun
  Interjection
  Phrase
  PhrasalVerb
}

model VocabCategory {
  id          String     @id @default(uuid())
  name        String
  orderIndex  Int        @map("order_index")
  wordlists   Wordlist[]

  @@map("vocab_categories")
}

model Wordlist {
  id            String       @id @default(uuid())
  categoryId    String       @map("category_id")
  title         String
  description   String?
  level         Level?
  orderIndex    Int          @map("order_index")
  vocabularies  Vocabulary[]
  discoveryTask DiscoveryTask?

  category      VocabCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("wordlists")
}

model Vocabulary {
  id            String        @id @default(uuid())
  wordlistId    String        @map("wordlist_id")
  word          String
  partOfSpeech  PartOfSpeech?
  level         Level?
  defIndo       String        @map("def_indo")
  defEng        String        @map("def_eng")
  collocations  Collocation[]
  wordFamilies  WordFamily[]

  wordlist      Wordlist      @relation(fields: [wordlistId], references: [id], onDelete: Cascade)

  @@map("vocabularies")
}

model Collocation {
  id          String     @id @default(uuid())
  vocabId     String     @map("vocab_id")
  text        String
  url         String?

  vocabulary  Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  @@map("collocations")
}

model WordFamily {
  id           String        @id @default(uuid())
  vocabId      String        @map("vocab_id")
  word         String
  partOfSpeech PartOfSpeech?
  url          String?

  vocabulary   Vocabulary    @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  @@map("word_families")
}

model AiConfig {
  id           String   @id @default(uuid())
  type         String   // e.g. 'grammar', 'vocab-discovery'
  name         String   // e.g. 'Discovery Config'
  baseUrl      String?  @map("base_url")
  apiKey       String?  @map("api_key")
  modelName    String?  @map("model_name")
  globalPrompt String?  @map("global_prompt") @db.Text
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("ai_configs")
}

model DiscoveryTask {
  id         String @id @default(uuid())
  wordlistId String @unique @map("wordlist_id") // 1-to-1 with Wordlist
  paragraphs DiscoveryParagraph[]

  wordlist   Wordlist @relation(fields: [wordlistId], references: [id], onDelete: Cascade)
  @@map("discovery_tasks")
}

model DiscoveryParagraph {
  id             String @id @default(uuid())
  taskId         String @map("task_id")
  orderIndex     Int    @map("order_index")
  
  options        ParagraphOption[]

  task           DiscoveryTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  @@map("discovery_paragraphs")
}

model ParagraphOption {
  id             String @id @default(uuid())
  paragraphId    String @map("paragraph_id")
  content        String @db.Text
  
  questions      DiscoveryQuestion[]

  paragraph      DiscoveryParagraph @relation(fields: [paragraphId], references: [id], onDelete: Cascade)
  @@map("paragraph_options")
}

model DiscoveryQuestion {
  id             String @id @default(uuid())
  optionId       String @map("option_id")
  orderIndex     Int    @map("order_index")
  questionText   String @map("question_text")

  option         ParagraphOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  @@map("discovery_questions")
}
